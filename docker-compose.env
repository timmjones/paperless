###############################################################################
# Paperless-ngx settings                                                      #
###############################################################################

# See http://docs.paperless-ngx.com/configuration/ for all available options.

# UID/GID are set in docker-compose.yml via USERMAP_UID/USERMAP_GID

# This is required if you will be exposing Paperless-ngx on a public domain
PAPERLESS_URL=https://paperless.tahome.us

# Secret key — set in .env, never commit
PAPERLESS_SECRET_KEY=${PAPERLESS_SECRET_KEY}

# Database password — must match PAPERLESS_DBPASS in .env
PAPERLESS_DBPASS=${PAPERLESS_DBPASS}

# Timezone
PAPERLESS_TIME_ZONE=America/Chicago

# OCR language
PAPERLESS_OCR_LANGUAGE=eng

# Performance: tune to available CPU cores (2 workers x 2 threads = 4 concurrent tasks)
PAPERLESS_TASK_WORKERS=2
PAPERLESS_THREADS_PER_WORKER=2

# Consumer settings
PAPERLESS_CONSUMER_POLLING=60
PAPERLESS_CONSUMER_DELETE_DUPLICATES=true
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=true

# OCR settings — skip avoids re-OCRing files that already have text
# skip_archive_file=with_text skips creating a separate archive for already-text PDFs
PAPERLESS_OCR_MODE=skip
PAPERLESS_OCR_SKIP_ARCHIVE_FILE=with_text

# Audit log retention (days)
PAPERLESS_AUDIT_LOG_RETENTION=365
